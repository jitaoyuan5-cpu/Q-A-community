{
  "name": "qa-community",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "node ./node_modules/vite/bin/vite.js",
    "build": "node ./node_modules/typescript/bin/tsc -b && node ./node_modules/vite/bin/vite.js build",
    "preview": "node ./node_modules/vite/bin/vite.js preview",
    "test": "node ./node_modules/vitest/vitest.mjs run",
    "test:watch": "node ./node_modules/vitest/vitest.mjs",
    "test:backend": "npm --prefix server run test",
    "test:backend:e2e": "npm --prefix server run test:e2e",
    "acceptance": "pwsh -NoProfile -ExecutionPolicy Bypass -File ./scripts/acceptance.ps1",
    "server:install": "npm --prefix server install",
    "server:dev": "pwsh -NoProfile -ExecutionPolicy Bypass -File ./scripts/server-dev.ps1",
    "server:migrate": "npm --prefix server run migrate",
    "server:seed": "npm --prefix server run seed"
  },
  "dependencies": {
    "date-fns": "^3.6.0",
    "lucide-react": "^0.487.0",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "react-router": "^7.13.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.1.12",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^22.10.2",
    "@types/react": "^18.3.14",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^4.7.0",
    "jsdom": "^25.0.1",
    "tailwindcss": "^4.1.12",
    "typescript": "^5.7.2",
    "vite": "^6.3.5",
    "vitest": "^2.1.8"
  }
}
