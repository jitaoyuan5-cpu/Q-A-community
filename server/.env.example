# AI assistant
# AI_PROVIDER options:
# - local: only site retrieval + local summary, no external model
# - openai: OpenAI official endpoint preset
# - openrouter: OpenRouter preset
# - deepseek: DeepSeek preset
# - moonshot: Moonshot preset
# - siliconflow: SiliconFlow preset
# - compatible: any OpenAI-compatible endpoint, fill AI_BASE_URL manually
AI_PROVIDER=local
AI_API_KEY=
# Optional: override preset endpoint, or required when AI_PROVIDER=compatible
AI_BASE_URL=
# Optional: override preset model
AI_MODEL=
AI_TIMEOUT_MS=12000
PUBLIC_API_RATE_LIMIT=120
